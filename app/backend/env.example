# Copy to `.env`. Natural language + optional FAISS similarity (requires local Ollama + Python faiss_service).

USE_OLLAMA_NL=false
USE_FAISS_SIMILAR=false

OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=llama3
OLLAMA_TIMEOUT_MS=60000
# true = always log each Ollama NL step (full prompts + raw response + parsed); false = off; unset = follow TRACE_STEPS
OLLAMA_LOG_STEPS=true

FAISS_SERVICE_URL=http://127.0.0.1:5100
FAISS_TIMEOUT_MS=120000
FAISS_TOP_K=80

# Absolute path to project root for the Python service when not using cwd defaults
# DSC_PROJECT_ROOT=/path/to/dsci558-project
